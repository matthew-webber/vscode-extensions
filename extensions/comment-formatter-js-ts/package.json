{
  "name": "comment-formatter-js-ts",
  "displayName": "Comment Formatter for JS/TS",
  "description": "A simple VSCode extension that formats comment blocks in JavaScript.",
  "version": "0.1.0",
  "publisher": "matthew-webber",
  "license": "MIT",
  "homepage": "https://github.com/matthew-webber/vscode-extensions/tree/master/extensions/comment-formatter-js-ts#readme",
  "bugs": {
    "url": "https://github.com/matthew-webber/vscode-extensions/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/matthew-webber/vscode-extensions.git",
    "directory": "extensions/comment-formatter-js-ts"
  },
  "engines": {
    "vscode": "^1.77.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "comment-formatter-js-ts.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "comment-formatter-js-ts.format",
        "title": "Format Comment Block"
      }
    ],
    "configuration": {
      "properties": {
        "comment-formatter-js-ts.formattingStyle": {
          "type": "string",
          "default": "lengthen",
          "enum": ["lengthen", "shorten"],
          "description": "Formatting style for comment blocks: lengthen or shorten."
        },
        "comment-formatter-js-ts.printWidthVariance": {
          "type": "number",
          "default": 8,
          "description": "Print-width variance for formatted comment blocks."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "build": "npm run compile",
    "check": "tsc --noEmit",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.77.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@typescript-eslint/eslint-plugin": "^5.56.0",
    "@typescript-eslint/parser": "^5.56.0",
    "eslint": "^8.36.0",
    "mocha": "^10.2.0",
    "typescript": "^4.9.5",
    "@vscode/test-electron": "^2.3.0"
  }
}
